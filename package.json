{
  "name": "back-end",
  "type": "module",
  "version": "1.0.0",
  "description": "medical-chatbot-backend",
  "main": "src/server.js",
  "author": "nguyenthangdev",
  "license": "MIT",
  "private": true,
  "scripts": {
    "lint": "eslint src --ext js --report-unused-disable-directives --max-warnings 0",
    "clean": "rm -rf build && mkdir build",
    "build": "yarn run clean && yarn run",
    "production": "cross-env BUILD_MODE=production node ./src/server.js",
    "dev": "cross-env BUILD_MODE=dev nodemon ./src/server.js",
    "bi:schema": "node src/scripts/apply-bi-schema.js",
    "bi:sync": "node src/scripts/sync-bi.js",
    "bi:sync:worker": "node src/scripts/bi-sync-worker.js",
    "bi:views": "node src/scripts/apply-bi-views.js",
    "bi:superset": "node src/scripts/setup-superset-datasets.js",
    "bi:dashboards": "node src/scripts/setup-superset-dashboards.js"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.4",
    "ms": "^2.1.3",
    "multer": "^2.1.1",
    "nodemon": "^3.1.14",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1",
    "unidecode": "^1.1.0"
  }
}
