{
  "name": "back-end",
  "type": "module",
  "version": "1.0.0",
  "description": "medical-chatbot-backend",
  "main": "src/server.js",
  "author": "nguyenthangdev",
  "license": "MIT",
  "private": true,
  "scripts": {
    "lint": "eslint src --ext js --report-unused-disable-directives --max-warnings 0",
    "clean": "rm -rf build && mkdir build",
    "build": "npm run clean && npm run",
    "production": "npm run build && cross-env BUILD_MODE=production node ./build/src/server.js",
    "dev": "cross-env BUILD_MODE=dev nodemon --exec ./src/server.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "ms": "^2.1.3",
    "multer": "^2.1.1",
    "nodemon": "^3.1.14",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1"
  }
}
